# Firebase Admin (server-side)
FIREBASE_PROJECT_ID=metropoleparking
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Client (browser-side, public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=metropoleparking.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=metropoleparking

# Emulator (uncomment for local dev)
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Admin seed email (first admin to create)
ADMIN_SEED_EMAIL=admin@turboparking.com

# API key pepper (for hashing turbo_station API keys)
# API_KEYS_PEPPER=
