rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════
    // ALL collections are server-side only (Admin SDK).
    // The Next.js API routes use firebase-admin which
    // bypasses these rules entirely.
    // The Python LPR scripts also use firebase-admin.
    //
    // These rules block ALL direct client-side access,
    // meaning even if someone has the API key, they
    // cannot read or write any data from the browser.
    // ══════════════════════════════════════════════════

    // Parking sessions (entry/exit records)
    match /parking_sessions/{sessionId} {
      allow read, write: if false;
    }

    // Parking config (validation rules, feature flags)
    match /parking_config/{locationId} {
      allow read, write: if false;
    }

    // Pricing config (used by Python scripts)
    match /pricing_config/{docId} {
      allow read, write: if false;
    }

    // Admin users
    match /parking_admins/{uid} {
      allow read, write: if false;
    }

    // Daily statistics
    match /daily_stats/{date} {
      allow read, write: if false;
    }

    // System status (LPR camera status)
    match /system_status/{docId} {
      allow read, write: if false;
    }

    // Error logs
    match /errors/{errorId} {
      allow read, write: if false;
    }

    // Catch-all: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
